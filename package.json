{
  "name": "mrn-mulla-kirana",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:customer": "cross-env VITE_APP_MODE=customer vite build",
    "build:admin": "cross-env VITE_APP_MODE=admin vite build",
    "build:apk:customer": "node scripts/switch-app.cjs customer && npm run update-icons:customer && npm run build:customer && npx cap sync android",
    "build:apk:admin": "node scripts/switch-app.cjs admin && npm run update-icons:admin && npm run build:admin && npx cap sync android",
    "update-icons:customer": "npx @capacitor/assets generate --android --assetPath assets/customer --iconBackgroundColor #ffffff --splashBackgroundColor #ffffff",
    "update-icons:admin": "npx @capacitor/assets generate --android --assetPath assets/admin --iconBackgroundColor #ffffff --splashBackgroundColor #ffffff",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor-community/keep-awake": "^5.0.0",
    "@capacitor-community/speech-recognition": "^6.0.1",
    "@capacitor-community/text-to-speech": "^8.0.0",
    "@capacitor-mlkit/barcode-scanning": "^6.0.0",
    "@capacitor/android": "^6.1.0",
    "@capacitor/app": "^6.0.3",
    "@capacitor/browser": "^6.0.6",
    "@capacitor/cli": "^6.1.0",
    "@capacitor/core": "^6.2.1",
    "@capacitor/geolocation": "^6.1.1",
    "@capacitor/local-notifications": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.5",
    "@supabase/supabase-js": "^2.97.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "html5-qrcode": "^2.3.8",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.28.0",
    "sonner": "^1.7.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^10.1.0",
    "supabase": "^2.76.12",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0"
  }
}
